# ============================================================
# Firebase (Client-side / Next.js public)
# Estos deben tener el prefijo NEXT_PUBLIC_ para que Next.js
# los exponga en el bundle del frontend
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=tu-api-key-aqui
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=tu-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=tu-app-id

# ============================================================
# Stripe (Client-side / public key)
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica

# ============================================================
# Backend API URL
# ============================================================
NEXT_PUBLIC_API_URL=https://tu-backend.onrender.com

# ============================================================
# URL canónica del frontend
# ============================================================
NEXT_PUBLIC_APP_URL=https://tu-app.web.app

# ============================================================
# Auth de desarrollo (SOLO para localhost)
# ============================================================
# NEXT_PUBLIC_ALLOW_DEV_AUTH=true
