# Firebase (optional). If you want real auth, fill these and disable dev auth.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Enable local/dev auth fallback for E2E and local testing (true/false)
NEXT_PUBLIC_ALLOW_DEV_AUTH=true

# Stripe (server only) - set these on your host environment
#
# ⚠ IMPORTANT: You need DIFFERENT keys for test vs production!
#
# LOCAL (stripe listen):
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_... (from: stripe listen --print-secret)
#
# PRODUCTION (Render):
#   STRIPE_SECRET_KEY=sk_live_... (Dashboard → Developers → API keys)
#   STRIPE_WEBHOOK_SECRET=whsec_... (Dashboard → Developers → Webhooks → your endpoint → signing secret)
#
# Checklist before going live:
#   1. Replace sk_test_ with sk_live_ in Render env vars
#   2. Create webhook endpoint in Dashboard (URL: https://noctip.com/api/webhooks/stripe)
#   3. Select event: checkout.session.completed
#   4. Copy the signing secret (different from stripe listen secret!)
#   5. Replace STRIPE_WEBHOOK_SECRET in Render with the production one
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Brevo (newsletter) - Get API key at https://app.brevo.com/settings/keys/api
# Create a contact list at https://app.brevo.com/contacts/lists
BREVO_API_KEY=
BREVO_LIST_ID=

# Meta (Facebook) Pixel - Get ID at https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel - Get ID at https://ads.tiktok.com/business/central/events
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Tawk.to (live chat) - Get IDs at https://dashboard.tawk.to/
# Property ID is the first part, Widget ID is the second part of the embed URL
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=
