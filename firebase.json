{
  "hosting": {
    "public": "recovery-system/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/es",
        "type": 302
      }
      ,
      {
        "source": "/favicon.ico",
        "destination": "/favicon.svg",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|webp|svg|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      }
      ,
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=0,s-maxage=0,must-revalidate"
          }
        ]
      }
    ],
    "cleanUrls": true
  }
}
